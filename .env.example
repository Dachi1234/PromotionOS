# ========================================
# PromotionOS — Environment Variables
# Copy to .env and adjust as needed
# ========================================

# ── Database ──────────────────────────
# Local: postgres://postgres:postgres@localhost:5432/promotionos
# Neon:  postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/promotionos
DATABASE_URL=postgres://postgres:postgres@localhost:5432/promotionos

# ── Redis ─────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────
JWT_SECRET=dev-secret-change-in-production

# ── Engine ────────────────────────────
ENABLE_WORKERS=true
PLAYER_CONTEXT_PROVIDER=mock
REWARD_GATEWAY=mock
ASSET_STORAGE_PROVIDER=local

# ── CORS (comma-separated origins) ───
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Studio (Next.js public vars) ─────
NEXT_PUBLIC_ENGINE_URL=http://localhost:3000
NEXT_PUBLIC_CANVAS_URL=http://localhost:3002

# ── Canvas (Next.js public vars) ─────
# NEXT_PUBLIC_ENGINE_URL is shared with Studio
ALLOWED_FRAME_ANCESTORS=*
